{
  "title": "MedShare Overview",
  "uid": "medshare-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "后端 QPS",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(rate(medshare_requests_total[1m]))", "refId": "A"}
      ]
    },
    {
      "type": "stat",
      "title": "错误率 (5xx)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {"expr": "sum(rate(medshare_requests_total{status=~\"5..\"}[1m])) / sum(rate(medshare_requests_total[1m]))", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "请求延迟 P95",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by(le, path)(rate(medshare_request_latency_seconds_bucket[5m])))", "legendFormat": "{{path}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "WebSocket 连接 / 审计条数",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {"expr": "medshare_ws_connections", "legendFormat": "WS", "refId": "A"},
        {"expr": "medshare_audit_events_emitted", "legendFormat": "Audit", "refId": "B"}
      ]
    }
  ]
}
