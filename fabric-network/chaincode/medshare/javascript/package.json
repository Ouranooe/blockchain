{
  "name": "medshare-chaincode",
  "version": "1.0.0",
  "description": "Minimal chaincode for medical data sharing demo",
  "main": "index.js",
  "scripts": {
    "start": "fabric-chaincode-node start",
    "test": "mocha --reporter spec --recursive test",
    "test:watch": "mocha --reporter spec --watch --recursive test",
    "coverage": "nyc --reporter=text --reporter=html mocha --recursive test"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "fabric-contract-api": "^2.5.8",
    "fabric-shim": "^2.5.8"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "chai-as-promised": "^7.1.1",
    "mocha": "^10.4.0",
    "nyc": "^15.1.0",
    "sinon": "^17.0.1",
    "sinon-chai": "^3.7.0"
  },
  "nyc": {
    "exclude": [
      "test/**"
    ],
    "check-coverage": false,
    "all": true
  }
}
